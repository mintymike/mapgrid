{
  "applicationId": "com.mapgrid.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "port": 0,
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "tokenSecurity": "one-time",
  "logging": {
    "enabled": true,
    "writeToLogFile": true
  },
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*",
    "window.*",
    "events.*",
    "storage.*"
  ],
  "globalVariables": {
    "APP_NAME": "MapGrid - Drone Search Area Controller"
  },
  "modes": {
    "window": {
      "title": "MapGrid - Drone Search Area Controller",
      "width": 1400,
      "height": 900,
      "minWidth": 1024,
      "minHeight": 768,
      "fullScreen": false,
      "alwaysOnTop": false,
      "enableInspector": false,
      "borderless": false,
      "maximize": false,
      "hidden": false,
      "resizable": true,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "mapgrid",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "clientLibrary": "/resources/js/neutralino.js",
    "binaryVersion": "5.4.0",
    "clientVersion": "5.4.0",
    "frontendLibrary": {
      "patchFile": "/dist/index.html",
      "devUrl": "http://localhost:5173"
    }
  },
  "buildSettings": {
    "win": {
      "icon": "resources/icons/appIcon.ico",
      "copyright": "MapGrid © 2025"
    }
  }
}
